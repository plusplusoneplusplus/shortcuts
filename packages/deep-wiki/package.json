{
  "name": "@plusplusoneplusplus/deep-wiki",
  "version": "1.1.0",
  "description": "CLI tool to auto-generate comprehensive wikis for any codebase",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "deep-wiki": "./dist/index.js"
  },
  "files": [
    "dist/index.js",
    "dist/index.js.map"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');try{fs.chmodSync('dist/index.js',0o755);}catch(e){if(process.platform!=='win32')throw e;}\"",
    "build:bundle": "node esbuild.config.mjs",
    "prepublishOnly": "npm run build:bundle && npm run test:run",
    "test": "vitest",
    "test:run": "vitest run",
    "coverage": "vitest run --coverage",
    "coverage:diff": "bash ../../scripts/coverage-diff.sh",
    "lint": "eslint src"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.3.0",
    "@octokit/rest": "^22.0.1",
    "@plusplusoneplusplus/forge": "^1.2.0",
    "azure-devops-node-api": "^14.1.0",
    "commander": "^12.1.0",
    "diff": "^5.2.0",
    "js-yaml": "^4.1.0",
    "pino": "^9.x",
    "pino-pretty": "^11.x",
    "better-sqlite3": "^11.9.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^1.6.1",
    "esbuild": "^0.21.5",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=24"
  }
}
