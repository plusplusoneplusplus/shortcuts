{
  "name": "@plusplusoneplusplus/coc-workflow",
  "version": "0.1.0",
  "description": "Pure DAG workflow compiler and executor for CoC YAML workflows",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "typesVersions": {
    "*": {
      "workflow": [
        "dist/workflow/index.d.ts"
      ],
      "ralph": [
        "dist/ralph/index.d.ts"
      ],
      "logger": [
        "dist/logger.d.ts"
      ],
      "errors": [
        "dist/errors/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": "./dist/index.js",
    "./workflow": "./dist/workflow/index.js",
    "./ralph": "./dist/ralph/index.js",
    "./logger": "./dist/logger.js",
    "./errors": "./dist/errors/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "test:run": "vitest run",
    "coverage": "vitest run --coverage",
    "coverage:diff": "bash ../../scripts/coverage-diff.sh",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@plusplusoneplusplus/coc-agent-sdk": "*",
    "js-yaml": "^4.3.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "typescript": "^5.3.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=24"
  }
}
