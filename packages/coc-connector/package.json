{
  "name": "@plusplusoneplusplus/coc-connector",
  "version": "0.1.0",
  "description": "Consolidated messaging connectors (Teams, WhatsApp) behind one MessagingConnector contract — no CoC/forge dependencies",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
    "./teams": { "types": "./dist/teams/index.d.ts", "default": "./dist/teams/index.js" },
    "./whatsapp": { "types": "./dist/whatsapp/index.d.ts", "default": "./dist/whatsapp/index.js" }
  },
  "files": [
    "dist",
    "teams",
    "whatsapp"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {},
  "optionalDependencies": {
    "@whiskeysockets/baileys": "^6.7.23",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "typescript": "^5.3.0",
    "vitest": "^4.1.10"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24"
  }
}
