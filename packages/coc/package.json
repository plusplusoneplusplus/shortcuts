{
  "name": "@plusplusoneplusplus/coc",
  "version": "1.0.0",
  "description": "CoC (Copilot of Copilot) - CLI tool for executing YAML-based AI pipelines",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "coc": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:client": "node scripts/build-client.mjs",
    "build:copy-client": "node -e \"const fs=require('fs');const p=require('path');function cp(s,d){fs.mkdirSync(d,{recursive:true});for(const f of fs.readdirSync(s))fs.copyFileSync(p.join(s,f),p.join(d,f));}cp(p.join('src','server','spa','client','dist'),p.join('dist','server','spa','client','dist'));\"",
    "build": "npm run build:client && tsc && npm run build:copy-client && node -e \"const fs=require('fs');try{fs.chmodSync('dist/index.js',0o755);}catch(e){if(process.platform!=='win32')throw e;}\"",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "npx playwright test --config test/e2e/playwright.config.ts",
    "lint": "eslint src"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@plusplusoneplusplus/coc-server": "1.0.0",
    "@plusplusoneplusplus/pipeline-core": "1.0.0",
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0",
    "monaco-editor": "^0.55.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.5.0",
    "autoprefixer": "^10.4.0",
    "esbuild": "^0.21.5",
    "highlight.js": "^11.9.0",
    "jsdom": "^27.0.1",
    "marked": "^12.0.0",
    "postcss": "^8.4.0",
    "postcss-cli": "^11.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
