{
  "name": "@plusplusoneplusplus/coc",
  "version": "1.2.0",
  "description": "CoC (Copilot of Copilot) - CLI and web dashboard for executing YAML-based AI workflows with queue, scheduling, wiki serving, and task management",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "coc": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:client": "node scripts/build-client.mjs",
    "build:copy-client": "node -e \"const fs=require('fs');const p=require('path');function cp(s,d){fs.mkdirSync(d,{recursive:true});for(const f of fs.readdirSync(s))fs.copyFileSync(p.join(s,f),p.join(d,f));}cp(p.join('src','server','spa','client','dist'),p.join('dist','server','spa','client','dist'));\"",
    "prebuild": "node scripts/prebuild.mjs",
    "build": "npm run build:client && tsc && npm run build:copy-client && node -e \"require('fs').copyFileSync('src/server/openapi.yaml','dist/server/openapi.yaml')\" && node -e \"const fs=require('fs');try{fs.chmodSync('dist/index.js',0o755);}catch(e){if(process.platform!=='win32')throw e;}\"",
    "test": "vitest",
    "test:run": "node scripts/run-vitest.mjs",
    "coverage": "vitest run --coverage",
    "coverage:diff": "bash ../../scripts/coverage-diff.sh",
    "test:e2e": "npx playwright test --config test/e2e/playwright.config.ts",
    "lint": "eslint src"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.150",
    "@excalidraw/excalidraw": "^0.18.1",
    "@github/copilot-sdk": "^0.3.0",
    "@monaco-editor/react": "^4.7.0",
    "@octokit/rest": "^22.0.1",
    "@openai/codex-sdk": "^0.133.0",
    "@plusplusoneplusplus/coc-agent-sdk": "^0.1.0",
    "@plusplusoneplusplus/coc-memory": "^0.1.0",
    "@plusplusoneplusplus/coc-workflow": "^0.1.0",
    "@plusplusoneplusplus/coc-client": "^0.1.0",
    "@plusplusoneplusplus/forge": "^1.2.0",
    "@plusplusoneplusplus/teams-bot": "^0.1.0",
    "@tanstack/react-table": "^8.21.3",
    "@tiptap/core": "^3.0.0",
    "@tiptap/extension-highlight": "^3.0.0",
    "@tiptap/extension-image": "^3.0.0",
    "@tiptap/extension-link": "^3.0.0",
    "@tiptap/extension-list": "3.22.4",
    "@tiptap/extension-placeholder": "^3.0.0",
    "@tiptap/extension-table": "^3.0.0",
    "@tiptap/extension-table-cell": "^3.0.0",
    "@tiptap/extension-table-header": "^3.0.0",
    "@tiptap/extension-table-row": "^3.0.0",
    "@tiptap/extension-task-item": "^3.0.0",
    "@tiptap/extension-task-list": "^3.0.0",
    "@tiptap/extension-text-align": "3.22.4",
    "@tiptap/extensions": "3.22.4",
    "@tiptap/pm": "^3.0.0",
    "@tiptap/react": "^3.0.0",
    "@tiptap/starter-kit": "^3.0.0",
    "@uiw/react-json-view": "^2.0.0-alpha.41",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "6.0.0",
    "azure-devops-node-api": "^14.1.0",
    "commander": "^12.1.0",
    "diff": "^5.2.0",
    "js-yaml": "^4.1.0",
    "monaco-editor": "^0.55.1",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "turndown": "^7.2.4",
    "ws": "^8.18.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@readme/openapi-parser": "^6.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@types/turndown": "^5.0.6",
    "@types/ws": "^8.5.0",
    "@vitest/coverage-v8": "^1.6.1",
    "autoprefixer": "^10.4.0",
    "esbuild": "^0.21.5",
    "fast-check": "^4.6.0",
    "highlight.js": "^11.9.0",
    "jsdom": "^27.0.1",
    "marked": "^12.0.0",
    "postcss": "^8.4.0",
    "postcss-cli": "^11.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "optionalDependencies": {
    "node-pty": "^1.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24"
  }
}
