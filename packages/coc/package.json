{
  "name": "@plusplusoneplusplus/coc",
  "version": "1.0.0",
  "description": "CoC (Copilot of Copilot) - CLI tool for executing YAML-based AI pipelines",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "coc": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:client": "node scripts/build-client.mjs",
    "build:copy-client": "node -e \"const fs=require('fs');const p=require('path');function cp(s,d){fs.mkdirSync(d,{recursive:true});for(const f of fs.readdirSync(s))fs.copyFileSync(p.join(s,f),p.join(d,f));}cp(p.join('src','server','spa','client','dist'),p.join('dist','server','spa','client','dist'));cp(p.join('src','server','wiki','spa','client','dist'),p.join('dist','server','wiki','spa','client','dist'));\"",
    "build": "npm run build:client && tsc && npm run build:copy-client && chmod +x dist/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "npx playwright test --config test/e2e/playwright.config.ts",
    "lint": "eslint src"
  },
  "dependencies": {
    "@plusplusoneplusplus/pipeline-core": "1.0.0",
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "esbuild": "^0.21.5",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
