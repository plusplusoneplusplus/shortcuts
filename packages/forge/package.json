{
  "name": "@plusplusoneplusplus/forge",
  "version": "1.2.0",
  "description": "Core AI engine: DAG workflow executor, Copilot SDK wrapper, map-reduce, memory system, process store, git CLI, skills, and utilities",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "typesVersions": {
    "*": {
      "ai": [
        "dist/ai/index.d.ts"
      ],
      "map-reduce": [
        "dist/map-reduce/index.d.ts"
      ],
      "pipeline": [
        "dist/pipeline/index.d.ts"
      ],
      "utils": [
        "dist/utils/index.d.ts"
      ],
      "tasks": [
        "dist/tasks/index.d.ts"
      ],
      "discovery": [
        "dist/discovery/index.d.ts"
      ],
      "editor/rendering": [
        "dist/editor/rendering/index.d.ts"
      ],
      "editor/parsing": [
        "dist/editor/parsing/index.d.ts"
      ],
      "editor/anchor": [
        "dist/editor/anchor.d.ts"
      ],
      "editor/anchor-types": [
        "dist/editor/anchor-types.d.ts"
      ],
      "editor/types": [
        "dist/editor/types.d.ts"
      ],
      "workflow": [
        "dist/workflow/index.d.ts"
      ],
      "git": [
        "dist/git/index.d.ts"
      ],
      "memory": [
        "dist/memory/index.d.ts"
      ],
      "templates": [
        "dist/templates/index.d.ts"
      ],
      "connectors": [
        "dist/connectors/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": "./dist/index.js",
    "./git": "./dist/git/index.js",
    "./git/normalize-url": "./dist/git/normalize-url.js",
    "./ai": "./dist/ai/index.js",
    "./map-reduce": "./dist/map-reduce/index.js",
    "./pipeline": "./dist/pipeline/index.js",
    "./utils": "./dist/utils/index.js",
    "./utils/path-utils": "./dist/utils/path-utils.js",
    "./tasks": "./dist/tasks/index.js",
    "./discovery": "./dist/discovery/index.js",
    "./editor/rendering": "./dist/editor/rendering/index.js",
    "./editor/parsing": "./dist/editor/parsing/index.js",
    "./editor/anchor": "./dist/editor/anchor.js",
    "./editor/anchor-types": "./dist/editor/anchor-types.js",
    "./editor/types": "./dist/editor/types.js",
    "./workflow": "./dist/workflow/index.js",
    "./memory": "./dist/memory/index.js",
    "./templates": "./dist/templates/index.js",
    "./connectors": "./dist/connectors/index.js"
  },
  "files": [
    "dist",
    "resources"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "peerDependencies": {
    "@openai/codex-sdk": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "@openai/codex-sdk": {
      "optional": true
    }
  },
  "scripts": {
    "prebuild": "node scripts/prebuild.mjs",
    "build": "tsc",
    "test": "vitest",
    "test:run": "vitest run",
    "coverage": "vitest run --coverage",
    "coverage:diff": "bash ../../scripts/coverage-diff.sh",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@plusplusoneplusplus/coc-workflow": "*",
    "@plusplusoneplusplus/coc-agent-sdk": "*",
    "@github/copilot-sdk": "^1.0.6",
    "@octokit/rest": "^22.0.1",
    "azure-devops-node-api": "^14.1.0",
    "better-sqlite3": "^12.11.1",
    "des.js": "^1.1.0",
    "diff": "^9.0.0",
    "js-md4": "^0.3.2",
    "js-yaml": "^4.3.0",
    "pino": "^9.x",
    "tunnel": "0.0.6",
    "underscore": "^1.13.8"
  },
  "devDependencies": {
    "@ampproject/remapping": "^2.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/diff": "^5.2.0",
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "pino-pretty": "^13.x",
    "typescript": "^5.3.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=24"
  }
}
